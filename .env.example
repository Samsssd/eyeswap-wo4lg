# ─────────────────────────────────────────────────────────────────────────────
# .env.example — commit this file, never put real secrets here
# Copy to .env.local (or .env.development / .env.preview / .env.production)
# and fill in your real values. Those files are git-ignored.
#
# NOTE: every var is EXPO_PUBLIC_*, meaning it is inlined into the client JS
# bundle and is therefore NOT secret. For CI (EAS Update via GitHub Actions),
# set these same names as GitHub Actions secrets — see README "Remote Deploy".
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of your backend API
EXPO_PUBLIC_API_URL=https://api.yourapp.com

# Supabase project URL + publishable (anon) key
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# App identifier issued by your backend
EXPO_PUBLIC_APP_ID=app_xxxxxx

# Token the mobile app uses to call your backend API
EXPO_PUBLIC_MOBILE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk publishable key
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxx

# Current environment — must be one of: development | preview | production
# (CI pins this to "preview" for the EAS Update workflow)
EXPO_PUBLIC_ENV=development
